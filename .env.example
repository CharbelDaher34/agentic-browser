# ============================================================================
# Agentic Browser — environment template.
# Copy to `.env` (local) or import into your host's secrets (deploy):
#     cp .env.example .env
# `.env` and `.env.*` are gitignored; never commit real keys. Only this template
# is tracked. Real env vars take precedence over values in `.env`.
# ============================================================================

# --- database ---------------------------------------------------------------
# Local: the bundled docker-compose Postgres (see docker-compose.yml).
# Deploy: your managed Postgres. For Supabase use the **Session pooler** string
# (host *.pooler.supabase.com, port 5432) — plain, with NO ?ssl= suffix (the app
# adds TLS + disables asyncpg's statement cache itself). postgres:// also works.
DATABASE_URL=postgresql://postgres:postgres@localhost:7935/postgres

# --- browser backend --------------------------------------------------------
# local       -> a real Chromium on this machine via Playwright (dev). Needs:
#                  uv run playwright install chromium
# browserbase -> browsers run in Browserbase's cloud (no local Chromium). Each
#                user supplies their own Browserbase key per session in the UI,
#                unless you set the server fallback below.
BROWSER_PROVIDER=local
# Headless only matters for the local provider (true on a server with no display;
# you still watch the browser via the live-view panel).
HEADLESS=true

# Orchestrator model (sub-agents pick from a safe menu of aliases at runtime).
AGENT_MODEL=anthropic:claude-sonnet-4-6

# --- access control ---------------------------------------------------------
# Public signups. Leave false on a deploy and pre-create the single account below.
ALLOW_REGISTRATION=false
# Created on startup if missing (idempotent). The password lives ONLY here / in
# your secret store — never in code. Omit both to disable bootstrapping.
BOOTSTRAP_USERNAME=
BOOTSTRAP_PASSWORD=

# --- BYOK enforcement (the important deploy switch) -------------------------
# false (dev): the server keys below are used as a fallback when a user/session
#              hasn't supplied its own key — convenient for local development.
# true (deploy): server keys are NEVER read — every model call AND Browserbase
#               session MUST use the user's own per-session keys. Set this so a
#               forgotten server key can never be served to web users. With this
#               on, users must bring at least the Anthropic key (the agent model).
ENFORCE_BYOK=false

# --- server-side provider keys (FALLBACK ONLY; ignored when ENFORCE_BYOK=true) ---
# Handy for a developer running locally; leave blank on a strict BYOK deploy.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
# Browserbase server fallback (only used by BROWSER_PROVIDER=browserbase).
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# --- secrets ----------------------------------------------------------------
# Stable key that encrypts users' BYOK keys at rest. KEEP IT CONSTANT FOREVER —
# if it changes, every stored key becomes undecryptable. Generate one with:
#     python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If left blank locally, a key is generated and saved to ./.app_secret (gitignored).
APP_SECRET=

# --- optional tuning --------------------------------------------------------
# CORS only matters if you serve the UI on a different origin (single-origin
# serving makes it moot). Comma-separated.
# CORS_ORIGINS=https://app.example.com,https://www.example.com
# Idle browser sessions are reaped (and their keys purged) after this many seconds.
# IDLE_TTL_SECONDS=1800
# Login token lifetime.
# TOKEN_TTL_HOURS=720
# Live-view screencast (local provider) quality/throughput.
# SCREENCAST_QUALITY=60
# SCREENCAST_EVERY_NTH_FRAME=1
