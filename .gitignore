.venv
.env

# python
__pycache__/
*.pyc

# runtime artifacts (screenshots / replay trail)
artifacts/

# frontend
frontend/node_modules/
# Build output — NOT committed (it churns hashed filenames on every build). It's
# rebuilt on demand: `run.sh`/`make run` run `npm run build`, and the Docker image
# builds it in its own stage (.dockerignore already excludes the committed copy).
# Serving the gateway directly via uvicorn requires building it first.
frontend/dist/

# uv
.python-version
computers/
.agents/
.env.*
# ...but DO track the documented template
!.env.example
node_modules/
